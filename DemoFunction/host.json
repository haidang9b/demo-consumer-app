{
    "version": "2.0",
    "telemetryMode": "OpenTelemetry",
    "extensions": {
        "serviceBus": {
            "autoCompleteMessages": false,
            "prefetchCount": 100,
            "maxAutoLockRenewalDuration": "00:05:00",
            "maxConcurrentCalls": 32,
            "maxMessageBatchSize": 100
        }
    },
    "concurrency": {
        "dynamicConcurrencyEnabled": true,
        "snapshotPersistenceEnabled": true
    }
}
